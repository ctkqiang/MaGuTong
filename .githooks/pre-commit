#!/usr/bin/env bash
# ============================================================
# Pre-commit Hook: Professional Language Check
# ============================================================
# Scans staged files for profanity or unprofessional language.
# Prevents commits that contain prohibited terms.
#
# To activate this hook, run:
#   git config core.hooksPath .githooks
# ============================================================

set -euo pipefail

PROHIBITED_PATTERN='(?i)\b(fuck|shit|damn|bitch|crap|wtfpl|asshole|bastard)\b'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

VIOLATIONS=""

for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        MATCHES=$(grep -Pn "$PROHIBITED_PATTERN" "$FILE" 2>/dev/null || true)
        if [ -n "$MATCHES" ]; then
            VIOLATIONS="${VIOLATIONS}\n  ${FILE}:\n${MATCHES}\n"
        fi
    fi
done

if [ -n "$VIOLATIONS" ]; then
    echo ""
    echo "============================================================"
    echo "  COMMIT REJECTED: Unprofessional language detected"
    echo "============================================================"
    echo ""
    echo "  The following files contain prohibited terms:"
    echo -e "$VIOLATIONS"
    echo "  Please replace the flagged terms with professional"
    echo "  alternatives before committing."
    echo ""
    echo "  Prohibited pattern: $PROHIBITED_PATTERN"
    echo "============================================================"
    echo ""
    exit 1
fi

exit 0
